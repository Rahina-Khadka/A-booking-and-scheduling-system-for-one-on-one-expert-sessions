<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Reviews - Expert Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Expert Sessions</a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">Welcome, <%= user.name %></span>
                <form action="/auth/logout" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <div class="col-md-12">
                <h2>My Reviews & Ratings</h2>
                <p class="lead">View and respond to client feedback</p>
            </div>
        </div>

        <!-- Statistics Overview -->
        <% if (stats.totalReviews > 0) { %>
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h5>Rating Overview</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3 text-center">
                                    <h2 class="text-primary mb-0"><%= stats.averageRating.toFixed(1) %></h2>
                                    <div class="text-warning mb-2">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <% if (i <= Math.round(stats.averageRating)) { %>
                                                ★
                                            <% } else { %>
                                                ☆
                                            <% } %>
                                        <% } %>
                                    </div>
                                    <small class="text-muted">Overall Rating</small>
                                </div>
                                <div class="col-md-6">
                                    <div class="row">
                                        <div class="col-6">
                                            <small><strong>Communication:</strong> <%= stats.averageCommunication.toFixed(1) %>/5</small><br>
                                            <small><strong>Expertise:</strong> <%= stats.averageExpertise.toFixed(1) %>/5</small>
                                        </div>
                                        <div class="col-6">
                                            <small><strong>Punctuality:</strong> <%= stats.averagePunctuality.toFixed(1) %>/5</small><br>
                                            <small><strong>Helpfulness:</strong> <%= stats.averageHelpfulness.toFixed(1) %>/5</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <h4 class="text-success mb-0"><%= stats.totalReviews %></h4>
                                        <small class="text-muted">Total Reviews</small>
                                    </div>
                                    <div class="text-center mt-2">
                                        <small class="text-success">
                                            <%= Math.round((stats.recommendationCount / stats.totalReviews) * 100) %>% recommend you
                                        </small>
                                    </div>
                                    <div class="text-center mt-1">
                                        <small class="text-muted">
                                            <%= stats.responseCount %>/<%= stats.totalReviews %> responses
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Reviews List -->
        <div class="row">
            <div class="col-md-12">
                <% if (reviews.length === 0) { %>
                    <div class="alert alert-info text-center">
                        <h5>No reviews yet</h5>
                        <p>Reviews from completed sessions will appear here.</p>
                        <a href="/expert/requests" class="btn btn-primary">View Session Requests</a>
                    </div>
                <% } else { %>
                    <% reviews.forEach(review => { %>
                        <div class="card mb-4">
                            <div class="card-header d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1"><%= review.title %></h6>
                                    <div class="text-warning mb-1">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <% if (i <= review.rating) { %>
                                                ★
                                            <% } else { %>
                                                ☆
                                            <% } %>
                                        <% } %>
                                        <span class="text-muted ms-2"><%= review.rating %>/5</span>
                                    </div>
                                    <small class="text-muted">
                                        by <%= review.user.name %> • 
                                        Session: <%= review.booking.topic %> • 
                                        <%= new Date(review.createdAt).toLocaleDateString() %>
                                    </small>
                                </div>
                                <% if (review.wouldRecommend) { %>
                                    <span class="badge bg-success">Recommends</span>
                                <% } %>
                            </div>
                            <div class="card-body">
                                <p class="mb-3"><%= review.comment %></p>
                                
                                <!-- Category Ratings -->
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <small class="text-muted">
                                            <strong>Communication:</strong> <%= review.categories.communication %>/5 •
                                            <strong>Expertise:</strong> <%= review.categories.expertise %>/5
                                        </small>
                                    </div>
                                    <div class="col-md-6">
                                        <small class="text-muted">
                                            <strong>Punctuality:</strong> <%= review.categories.punctuality %>/5 •
                                            <strong>Helpfulness:</strong> <%= review.categories.helpfulness %>/5
                                        </small>
                                    </div>
                                </div>
                                
                                <!-- Expert Response Section -->
                                <% if (review.expertResponse && review.expertResponse.comment) { %>
                                    <div class="alert alert-light">
                                        <small class="text-muted"><strong>Your Response:</strong></small>
                                        <p class="mb-1"><%= review.expertResponse.comment %></p>
                                        <small class="text-muted">
                                            Responded on <%= new Date(review.expertResponse.respondedAt).toLocaleDateString() %>
                                        </small>
                                    </div>
                                <% } else { %>
                                    <div class="mt-3">
                                        <button class="btn btn-outline-primary btn-sm" 
                                                onclick="showResponseForm('<%= review._id %>')">
                                            Respond to Review
                                        </button>
                                        
                                        <!-- Response Form (Hidden by default) -->
                                        <div id="response-form-<%= review._id %>" class="mt-3" style="display: none;">
                                            <div class="card">
                                                <div class="card-body">
                                                    <h6>Respond to this review</h6>
                                                    <textarea class="form-control mb-2" 
                                                              id="response-text-<%= review._id %>"
                                                              placeholder="Write your response..." 
                                                              maxlength="500" rows="3"></textarea>
                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-primary btn-sm" 
                                                                onclick="submitResponse('<%= review._id %>')">
                                                            Submit Response
                                                        </button>
                                                        <button class="btn btn-secondary btn-sm" 
                                                                onclick="hideResponseForm('<%= review._id %>')">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <!-- Back to Dashboard -->
        <div class="row mt-4">
            <div class="col-md-12">
                <a href="/dashboard/expert" class="btn btn-secondary">← Back to Dashboard</a>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showResponseForm(reviewId) {
            document.getElementById(`response-form-${reviewId}`).style.display = 'block';
        }
        
        function hideResponseForm(reviewId) {
            document.getElementById(`response-form-${reviewId}`).style.display = 'none';
            document.getElementById(`response-text-${reviewId}`).value = '';
        }
        
        async function submitResponse(reviewId) {
            const responseText = document.getElementById(`response-text-${reviewId}`).value.trim();
            
            if (!responseText) {
                alert('Please enter a response');
                return;
            }
            
            try {
                const response = await fetch(`/booking/review/${reviewId}/respond`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ response: responseText })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    location.reload(); // Refresh to show the response
                } else {
                    alert('Error submitting response: ' + result.error);
                }
            } catch (error) {
                alert('Error submitting response. Please try again.');
            }
        }
    </script>
</body>
</html>