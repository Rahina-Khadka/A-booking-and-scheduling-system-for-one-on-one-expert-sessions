<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Session Requests - Expert Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-warning">
        <div class="container">
            <a class="navbar-brand" href="/">Expert Sessions - Requests</a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">Welcome, <%= user.name %></span>
                <form action="/auth/logout" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <div class="col-md-12">
                <h2>Session Requests</h2>
                <p class="lead">Manage your incoming session requests and bookings</p>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body text-center">
                        <h4><%= stats.pending %></h4>
                        <small>Pending Requests</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h4><%= stats.confirmed %></h4>
                        <small>Confirmed Sessions</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h4><%= stats.completed %></h4>
                        <small>Completed Sessions</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-secondary text-white">
                    <div class="card-body text-center">
                        <h4><%= stats.cancelled %></h4>
                        <small>Cancelled Sessions</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Controls -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        <form method="GET" action="/expert/requests" class="row g-3">
                            <div class="col-md-4">
                                <label for="status" class="form-label">Filter by Status</label>
                                <select class="form-control" id="status" name="status">
                                    <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All Requests</option>
                                    <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="confirmed" <%= currentStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                    <option value="completed" <%= currentStatus === 'completed' ? 'selected' : '' %>>Completed</option>
                                    <option value="cancelled" <%= currentStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">&nbsp;</label>
                                <button type="submit" class="btn btn-primary d-block">Filter</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Requests List -->
        <div class="row">
            <div class="col-md-12">
                <% if (bookings.length === 0) { %>
                    <div class="alert alert-info text-center">
                        <h5>No session requests found</h5>
                        <p>
                            <% if (currentStatus === 'pending') { %>
                                No pending requests at the moment.
                            <% } else if (currentStatus === 'all') { %>
                                You haven't received any session requests yet.
                            <% } else { %>
                                No <%= currentStatus %> sessions found.
                            <% } %>
                        </p>
                    </div>
                <% } else { %>
                    <% bookings.forEach(booking => { %>
                        <div class="card mb-3">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>Booking #<%= booking._id.toString().slice(-8).toUpperCase() %></strong>
                                    <span class="badge ms-2 <%= booking.status === 'confirmed' ? 'bg-success' : booking.status === 'pending' ? 'bg-warning' : booking.status === 'completed' ? 'bg-primary' : 'bg-danger' %>">
                                        <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                                    </span>
                                </div>
                                <small class="text-muted">
                                    Requested: <%= new Date(booking.createdAt).toLocaleDateString() %>
                                </small>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h6>Session Details</h6>
                                        <ul class="list-unstyled">
                                            <li><strong>Topic:</strong> <%= booking.topic %></li>
                                            <li><strong>Date:</strong> <%= new Date(booking.sessionDate).toLocaleDateString() %></li>
                                            <li><strong>Time:</strong> <%= booking.sessionTime %></li>
                                            <li><strong>Duration:</strong> <%= booking.duration %> minutes</li>
                                            <li><strong>Amount:</strong> $<%= booking.totalAmount.toFixed(2) %></li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h6>Client Information</h6>
                                        <ul class="list-unstyled">
                                            <li><strong>Name:</strong> <%= booking.user.name %></li>
                                            <li><strong>Email:</strong> <%= booking.user.email %></li>
                                        </ul>
                                        
                                        <% if (booking.meetingLink) { %>
                                            <div class="mt-2">
                                                <strong>Meeting Link:</strong><br>
                                                <a href="<%= booking.meetingLink %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    Join Meeting
                                                </a>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <% if (booking.description) { %>
                                    <div class="mt-3">
                                        <h6>Additional Details</h6>
                                        <p class="text-muted"><%= booking.description %></p>
                                    </div>
                                <% } %>
                                
                                <% if (booking.notes) { %>
                                    <div class="mt-3">
                                        <div class="alert alert-info">
                                            <strong>Your Notes:</strong> <%= booking.notes %>
                                        </div>
                                    </div>
                                <% } %>
                                
                                <!-- Action Buttons -->
                                <div class="mt-3">
                                    <% if (booking.status === 'pending') { %>
                                        <div class="row">
                                            <div class="col-md-8">
                                                <div class="mb-2">
                                                    <input type="text" class="form-control form-control-sm" 
                                                           id="meetingLink_<%= booking._id %>" 
                                                           placeholder="Meeting link (optional)" 
                                                           value="<%= booking.meetingLink || '' %>">
                                                </div>
                                                <div class="mb-2">
                                                    <textarea class="form-control form-control-sm" 
                                                              id="notes_<%= booking._id %>" 
                                                              placeholder="Add notes for the client (optional)" 
                                                              rows="2"><%= booking.notes || '' %></textarea>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="d-grid gap-2">
                                                    <button class="btn btn-success btn-sm" 
                                                            onclick="updateBooking('<%= booking._id %>', 'confirmed')">
                                                        ✓ Confirm Session
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm" 
                                                            onclick="updateBooking('<%= booking._id %>', 'cancelled')">
                                                        ✗ Decline
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    <% } else if (booking.status === 'confirmed') { %>
                                        <div class="row">
                                            <div class="col-md-8">
                                                <div class="alert alert-success py-2">
                                                    <small>✓ Session confirmed. Don't forget to join at the scheduled time!</small>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="d-grid">
                                                    <button class="btn btn-primary btn-sm" 
                                                            onclick="updateBooking('<%= booking._id %>', 'completed')">
                                                        Mark as Completed
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    <% } else if (booking.status === 'completed') { %>
                                        <div class="alert alert-primary py-2">
                                            <small>✓ Session completed. Earnings have been added to your account.</small>
                                        </div>
                                    <% } else if (booking.status === 'cancelled') { %>
                                        <div class="alert alert-secondary py-2">
                                            <small>✗ Session was cancelled.</small>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <!-- Back to Dashboard -->
        <div class="row mt-4">
            <div class="col-md-12">
                <a href="/dashboard/expert" class="btn btn-secondary">← Back to Dashboard</a>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function updateBooking(bookingId, status) {
            try {
                const meetingLink = document.getElementById(`meetingLink_${bookingId}`)?.value || '';
                const notes = document.getElementById(`notes_${bookingId}`)?.value || '';
                
                const response = await fetch(`/expert/update-booking/${bookingId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ 
                        status, 
                        notes: notes.trim(),
                        meetingLink: meetingLink.trim()
                    })
                });

                const result = await response.json();
                
                if (result.success) {
                    location.reload(); // Refresh the page to show updated status
                } else {
                    alert('Error updating booking: ' + result.error);
                }
            } catch (error) {
                alert('Error updating booking. Please try again.');
                console.error('Error:', error);
            }
        }
    </script>
</body>
</html>