<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Booking & Scheduling System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Expert Sessions</a>
            <div class="navbar-nav ms-auto">
                <% if (typeof user !== 'undefined' && user) { %>
                    <span class="navbar-text me-3">Welcome, <%= user.name %></span>
                    <form action="/auth/logout" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                    </form>
                <% } else { %>
                    <a class="nav-link" href="/auth/login">Login</a>
                    <a class="nav-link" href="/auth/register">Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <!-- AI Neural Network Background Animation -->
        <div class="neural-network">
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="data-particle"></div>
            <div class="data-particle"></div>
            <div class="data-particle"></div>
            <div class="data-particle"></div>
        </div>
        
        <!-- Decorative Stickers -->
        <div class="sticker-element">🤖</div>
        <div class="sticker-element">💻</div>
        <div class="sticker-element">🧠</div>
        <div class="sticker-element">⚡</div>
        
        <div class="hero-section text-center py-5">
            <div class="container">
                <h1 class="display-4 mb-4">Expert Sessions Booking</h1>
                <p class="lead mb-4">Connect with experts for one-on-one sessions</p>
                
                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="row justify-content-center">
                        <div class="col-md-8">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">🎉 Welcome back, <%= user.name %>!</h5>
                                    <p class="card-text">You are logged in as a <strong><%= user.role %></strong>.</p>
                                    <% if (user.role === 'admin') { %>
                                        <a href="/dashboard/admin" class="btn btn-danger btn-lg">
                                            <i class="fas fa-cog me-2"></i>Go to Admin Dashboard
                                        </a>
                                    <% } else if (user.role === 'expert') { %>
                                        <a href="/dashboard/expert" class="btn btn-success btn-lg">
                                            <i class="fas fa-chalkboard-teacher me-2"></i>Go to Expert Dashboard
                                        </a>
                                    <% } else { %>
                                        <a href="/dashboard/user" class="btn btn-primary btn-lg">
                                            <i class="fas fa-user me-2"></i>Go to User Dashboard
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="row justify-content-center">
                        <div class="col-md-10">
                            <div class="card">
                                <div class="card-body text-center">
                                    <h5 class="card-title">🚀 Access Your Account</h5>
                                    <p class="card-text">Choose your role and start your journey with our expert community</p>
                                    
                                    <!-- Equal Treatment for Users and Experts -->
                                    <div class="row g-4 mb-4">
                                        <div class="col-md-6">
                                            <div class="card border-primary h-100 role-card">
                                                <div class="card-body d-flex flex-column">
                                                    <div class="text-center mb-3">
                                                        <div class="role-icon">👥</div>
                                                        <h6 class="card-title text-primary mb-2">For Learners</h6>
                                                    </div>
                                                    <p class="card-text flex-grow-1">
                                                        <strong>Learn & Grow</strong><br>
                                                        • Book sessions with verified experts<br>
                                                        • Access diverse expertise areas<br>
                                                        • Flexible scheduling options<br>
                                                        • Rate and review sessions
                                                    </p>
                                                    <div class="mt-auto">
                                                        <span class="badge bg-primary">Perfect for Growth</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <div class="card border-success h-100 role-card">
                                                <div class="card-body d-flex flex-column">
                                                    <div class="text-center mb-3">
                                                        <div class="role-icon">🎓</div>
                                                        <h6 class="card-title text-success mb-2">For Experts</h6>
                                                    </div>
                                                    <p class="card-text flex-grow-1">
                                                        <strong>Share & Earn</strong><br>
                                                        • Share your expertise globally<br>
                                                        • Set your own schedule & rates<br>
                                                        • Build your professional network<br>
                                                        • Track earnings and reviews
                                                    </p>
                                                    <div class="mt-auto">
                                                        <span class="badge bg-success">Perfect for Professionals</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex justify-content-center gap-3 mb-4">
                                        <a href="/auth/login" class="btn btn-primary btn-lg px-4">
                                            <i class="fas fa-sign-in-alt me-2"></i>Login
                                        </a>
                                        <a href="/auth/register" class="btn btn-outline-primary btn-lg px-4">
                                            <i class="fas fa-user-plus me-2"></i>Register
                                        </a>
                                    </div>
                                    
                                    <hr class="my-4">
                                    
                                    <div class="admin-section">
                                        <p class="mb-2"><strong>🔐 Admin Access</strong></p>
                                        <a href="/auth/google" class="btn btn-danger">
                                            <i class="fab fa-google me-2"></i>Admin Login with Google
                                        </a>
                                        <br>
                                        <small class="text-muted mt-2 d-block">Restricted to authorized accounts only</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="features-section py-5 bg-light">
            <div class="container">
                <div class="row text-center mb-4">
                    <div class="col-12">
                        <h3>🤖 AI-Powered Expert Matching</h3>
                        <p class="lead text-muted">Advanced technology connecting learners with the perfect experts</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 text-center mb-4">
                        <div class="feature-icon mb-3">🎯</div>
                        <h4>Smart Booking</h4>
                        <p>AI-enhanced matching system finds the perfect expert for your learning goals with intelligent scheduling</p>
                    </div>
                    <div class="col-md-4 text-center mb-4">
                        <div class="feature-icon mb-3">🌐</div>
                        <h4>Global Expert Network</h4>
                        <p>Connect with verified experts worldwide through our AI-curated network of professionals across all domains</p>
                    </div>
                    <div class="col-md-4 text-center mb-4">
                        <div class="feature-icon mb-3">🔒</div>
                        <h4>Secure AI Platform</h4>
                        <p>Advanced security protocols and AI-powered fraud detection ensure safe, reliable learning experiences</p>
                    </div>
                </div>
                
                <div class="row mt-5">
                    <div class="col-12 text-center">
                        <div class="ai-stats">
                            <div class="row">
                                <div class="col-md-3 mb-3">
                                    <div class="stat-item">
                                        <div class="stat-number">10K+</div>
                                        <div class="stat-label">Expert Sessions</div>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="stat-item">
                                        <div class="stat-number">95%</div>
                                        <div class="stat-label">Match Accuracy</div>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="stat-item">
                                        <div class="stat-number">500+</div>
                                        <div class="stat-label">Verified Experts</div>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="stat-item">
                                        <div class="stat-number">24/7</div>
                                        <div class="stat-label">AI Support</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>