<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Experts - Booking & Scheduling System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Expert Sessions</a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">Welcome, <%= user.name %></span>
                <form action="/auth/logout" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <div class="col-md-12">
                <h2>Browse Experts</h2>
                <p class="lead">Find and book sessions with qualified experts</p>
            </div>
        </div>

        <!-- Search and Filter -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        <form method="GET" action="/booking/experts">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="search" class="form-label">Search Experts</label>
                                        <input type="text" class="form-control" id="search" name="search" 
                                               value="<%= search %>" placeholder="Search by name, expertise, or bio">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="expertise" class="form-label">Filter by Expertise</label>
                                        <select class="form-control" id="expertise" name="expertise">
                                            <option value="">All Expertise Areas</option>
                                            <% expertiseList.forEach(exp => { %>
                                                <option value="<%= exp %>" <%= selectedExpertise === exp ? 'selected' : '' %>><%= exp %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="mb-3">
                                        <label class="form-label">&nbsp;</label>
                                        <button type="submit" class="btn btn-primary d-block">Search</button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Experts List -->
        <div class="row">
            <% if (experts.length === 0) { %>
                <div class="col-md-12">
                    <div class="alert alert-info">
                        <h5>No experts found</h5>
                        <p>Try adjusting your search criteria or check back later for more experts.</p>
                    </div>
                </div>
            <% } else { %>
                <% experts.forEach(expert => { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title"><%= expert.name %></h5>
                                <h6 class="card-subtitle mb-2 text-muted"><%= expert.expertise %></h6>
                                <p class="card-text">
                                    <%= expert.bio ? expert.bio.substring(0, 100) + (expert.bio.length > 100 ? '...' : '') : 'No bio available' %>
                                </p>
                                <div class="mb-2">
                                    <strong>Rate:</strong> $<%= expert.hourlyRate %>/hour
                                </div>
                                
                                <!-- Rating Display -->
                                <% if (expert.totalReviews > 0) { %>
                                    <div class="mb-2">
                                        <div class="text-warning d-inline">
                                            <% for (let i = 1; i <= 5; i++) { %>
                                                <% if (i <= Math.round(expert.averageRating)) { %>
                                                    ★
                                                <% } else { %>
                                                    ☆
                                                <% } %>
                                            <% } %>
                                        </div>
                                        <small class="text-muted ms-1">
                                            <%= expert.averageRating.toFixed(1) %> (<%= expert.totalReviews %> review<%= expert.totalReviews !== 1 ? 's' : '' %>)
                                        </small>
                                    </div>
                                <% } else { %>
                                    <div class="mb-2">
                                        <small class="text-muted">No reviews yet</small>
                                    </div>
                                <% } %>
                                <% if (expert.skills && expert.skills.length > 0) { %>
                                    <div class="mb-3">
                                        <small class="text-muted">Skills:</small><br>
                                        <% expert.skills.slice(0, 3).forEach(skill => { %>
                                            <span class="badge bg-secondary me-1"><%= skill %></span>
                                        <% }) %>
                                        <% if (expert.skills.length > 3) { %>
                                            <span class="badge bg-light text-dark">+<%= expert.skills.length - 3 %> more</span>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>
                            <div class="card-footer">
                                <div class="d-grid gap-2">
                                    <a href="/booking/expert/<%= expert._id %>" class="btn btn-outline-primary btn-sm">View Profile</a>
                                    <a href="/booking/book/<%= expert._id %>" class="btn btn-primary btn-sm">Book Session</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <!-- Back to Dashboard -->
        <div class="row mt-4">
            <div class="col-md-12">
                <a href="/dashboard/user" class="btn btn-secondary">← Back to Dashboard</a>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>