<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Bookings - Booking & Scheduling System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Expert Sessions</a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">Welcome, <%= user.name %></span>
                <form action="/auth/logout" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <div class="col-md-12">
                <h2>
                    <% if (user.role === 'user') { %>
                        My Bookings
                    <% } else { %>
                        Session Requests
                    <% } %>
                </h2>
                <p class="lead">
                    <% if (user.role === 'user') { %>
                        View and manage your booked sessions
                    <% } else { %>
                        Manage incoming session requests from users
                    <% } %>
                </p>
            </div>
        </div>

        <% if (bookings.length === 0) { %>
            <div class="row">
                <div class="col-md-12">
                    <div class="alert alert-info text-center">
                        <h5>
                            <% if (user.role === 'user') { %>
                                No bookings yet
                            <% } else { %>
                                No session requests yet
                            <% } %>
                        </h5>
                        <p>
                            <% if (user.role === 'user') { %>
                                <a href="/booking/experts" class="btn btn-primary">Browse Experts</a>
                            <% } else { %>
                                Session requests from users will appear here.
                            <% } %>
                        </p>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="row">
                <% bookings.forEach(booking => { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <small class="text-muted">#<%= booking._id.toString().slice(-8).toUpperCase() %></small>
                                <span class="badge <%= booking.status === 'confirmed' ? 'bg-success' : booking.status === 'pending' ? 'bg-warning' : booking.status === 'completed' ? 'bg-primary' : 'bg-danger' %>">
                                    <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                                </span>
                            </div>
                            <div class="card-body">
                                <h6 class="card-title">
                                    <% if (user.role === 'user') { %>
                                        <%= booking.expert.name %>
                                    <% } else { %>
                                        <%= booking.user.name %>
                                    <% } %>
                                </h6>
                                <p class="card-text">
                                    <strong>Topic:</strong> <%= booking.topic %><br>
                                    <strong>Date:</strong> <%= new Date(booking.sessionDate).toLocaleDateString() %><br>
                                    <strong>Time:</strong> <%= booking.sessionTime %><br>
                                    <strong>Duration:</strong> <%= booking.duration %> minutes<br>
                                    <strong>Amount:</strong> $<%= booking.totalAmount.toFixed(2) %>
                                </p>
                                
                                <% if (booking.description) { %>
                                    <p class="card-text">
                                        <small class="text-muted">
                                            <%= booking.description.length > 100 ? booking.description.substring(0, 100) + '...' : booking.description %>
                                        </small>
                                    </p>
                                <% } %>
                                
                                <% if (booking.notes) { %>
                                    <div class="alert alert-info py-2">
                                        <small><strong>Expert Notes:</strong> <%= booking.notes %></small>
                                    </div>
                                <% } %>
                            </div>
                            <div class="card-footer">
                                <% if (user.role === 'expert' && booking.status === 'pending') { %>
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-success btn-sm" onclick="updateBookingStatus('<%= booking._id %>', 'confirmed')">
                                            Confirm Session
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" onclick="updateBookingStatus('<%= booking._id %>', 'cancelled')">
                                            Decline
                                        </button>
                                    </div>
                                <% } else if (user.role === 'expert' && booking.status === 'confirmed') { %>
                                    <div class="d-grid">
                                        <button class="btn btn-primary btn-sm" onclick="updateBookingStatus('<%= booking._id %>', 'completed')">
                                            Mark as Completed
                                        </button>
                                    </div>
                                <% } else if (user.role === 'user') { %>
                                    <div class="d-grid">
                                        <% if (booking.status === 'pending') { %>
                                            <small class="text-muted">Waiting for expert confirmation</small>
                                        <% } else if (booking.status === 'confirmed') { %>
                                            <small class="text-success">✓ Session confirmed</small>
                                        <% } else if (booking.status === 'completed') { %>
                                            <small class="text-primary">✓ Session completed</small>
                                            <% if (booking.hasReview) { %>
                                                <small class="text-success d-block mt-1">✓ Review submitted</small>
                                            <% } else { %>
                                                <a href="/booking/review/<%= booking._id %>" class="btn btn-outline-primary btn-sm mt-2">
                                                    Write Review
                                                </a>
                                            <% } %>
                                        <% } else { %>
                                            <small class="text-danger">Session cancelled</small>
                                        <% } %>
                                    </div>
                                <% } %>
                                
                                <small class="text-muted d-block mt-2">
                                    Booked: <%= new Date(booking.createdAt).toLocaleDateString() %>
                                </small>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <!-- Back to Dashboard -->
        <div class="row mt-4">
            <div class="col-md-12">
                <a href="/dashboard/<%= user.role %>" class="btn btn-secondary">← Back to Dashboard</a>
                <% if (user.role === 'user') { %>
                    <a href="/booking/experts" class="btn btn-primary ms-2">Book New Session</a>
                <% } %>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function updateBookingStatus(bookingId, status) {
            try {
                const response = await fetch(`/booking/update-status/${bookingId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ status })
                });

                const result = await response.json();
                
                if (result.success) {
                    location.reload(); // Refresh the page to show updated status
                } else {
                    alert('Error updating booking status: ' + result.error);
                }
            } catch (error) {
                alert('Error updating booking status. Please try again.');
            }
        }
    </script>
</body>
</html>